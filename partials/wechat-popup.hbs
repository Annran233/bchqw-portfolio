<div class="wechat-qr-overlay" id="wechatQROverlay" onclick="hideWechatQR()"></div>
<div class="wechat-qr-popup" id="wechatQRPopup">
    <span class="wechat-qr-close" onclick="hideWechatQR()">&times;</span>
    <div class="wechat-qr-cards">
        <div class="wechat-qr-card">
            <img src="https://img-cfr2.chatongxue.top/wechat-qr-mf.webp" alt="微信公众号二维码" class="wechat-qr-img" loading="lazy">
            <span class="wechat-qr-label">微信公众号</span>
        </div>
        <div class="wechat-qr-card">
            <img src="https://img-cfr2.chatongxue.top/wechat-qr-channel.webp" alt="微信视频号二维码" class="wechat-qr-img" loading="lazy">
            <span class="wechat-qr-label">微信视频号</span>
        </div>
    </div>
</div>
